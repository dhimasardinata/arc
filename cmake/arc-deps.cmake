        elseif(feature STREQUAL "twai")
            list(APPEND result esp_driver_twai)
        elseif(feature STREQUAL "udp")
            list(APPEND result esp_event esp_netif esp_wifi lwip nvs_flash)
        elseif(feature STREQUAL "uart")
            list(APPEND result esp_driver_uart)
        elseif(feature STREQUAL "ulp")
            list(APPEND result ulp)
        elseif(feature STREQUAL "ulp_ml")
            list(APPEND result ulp)
        elseif(feature STREQUAL "espnow")
            list(APPEND result esp_event esp_netif esp_wifi nvs_flash)
        elseif(feature STREQUAL "usb_host")
            list(APPEND result esp_hal_usb)
        elseif(feature STREQUAL "fuse")
            list(APPEND result efuse)
        elseif(feature STREQUAL "fs")
            list(APPEND result esp_partition fatfs spiffs vfs wear_levelling)
        elseif(feature STREQUAL "sd")
            list(APPEND result esp_driver_sdmmc fatfs sdmmc vfs)
        elseif(feature STREQUAL "tcp")
            list(APPEND result lwip)
        elseif(feature STREQUAL "tls")
            list(APPEND result esp-tls lwip)
        elseif(feature STREQUAL "time")
            list(APPEND result esp_timer)
        elseif(feature STREQUAL "trax")
            list(APPEND result esp_hw_support esp_system hal soc xtensa)
        elseif(feature STREQUAL "usb")
            list(APPEND result esp_driver_usb_serial_jtag)
        elseif(feature STREQUAL "wdt")
            list(APPEND result esp_system)
        elseif(feature STREQUAL "wavefront")
            list(APPEND result esp_driver_i2s)
        elseif(feature STREQUAL "xts")
            list(APPEND result esp_partition spi_flash)
        else()
            message(FATAL_ERROR "Unknown Arc feature '${feature}'")
        endif()
    endforeach()

    list(REMOVE_DUPLICATES result)
    set(${out} "${result}" PARENT_SCOPE)
endfunction()
